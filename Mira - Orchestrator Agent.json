        "jsCode": "const raw = $json.output[0].content[0].text;\n\nconst result = JSON.parse(raw);\n\nlet selected_agent = \"\";\n\nswitch (result.intent) {\n  case \"RISK\":\n    selected_agent = \"Risk Assessor\";\n    break;\n\n  case \"STATUS\":\n    selected_agent = \"Status Reporter\";\n    break;\n\n  case \"PLANNER\":\n    selected_agent = \"Planner\";\n    break;\n\n  case \"MILESTONE\":\n    selected_agent = \"Milestone Tracker\";\n    break;\n}\n\nreturn [{\n  json: {\n    intent: result.intent,\n    confidence: result.confidence,\n    question: $('Input to JSON').first().json.question,\n    selected_agent\n  }\n}];"
